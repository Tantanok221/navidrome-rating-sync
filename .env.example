# Primary Navidrome (source of truth)
PRIMARY_URL=https://primary.example.com
PRIMARY_USERNAME=admin
PRIMARY_PASSWORD=replace_me
PRIMARY_VERIFY_TLS=true

# Secondary Navidrome (will be updated)
SECONDARY_URL=https://secondary.example.com
SECONDARY_USERNAME=admin
SECONDARY_PASSWORD=replace_me
SECONDARY_VERIFY_TLS=true

# Sync behavior
SYNC_FAVORITES=true
SYNC_RATINGS=true
STRICT_FAVORITES=false
STRICT_RATINGS=false

# Safety
DRY_RUN=true

# Runtime
REQUEST_TIMEOUT_SEC=30
CLIENT_NAME=navidrome-rating-sync
